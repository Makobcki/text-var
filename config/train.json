{
  "seed": 42,
  "device": "cuda",
  "batch_size": 1,
  "learning_rate": 0.0001,
  "weight_decay": 0.01,
  "max_steps": 1000,
  "grad_clip_norm": 1.0,
  "save_every": 200,
  "checkpoint_path": "checkpoints/var_model_latest.pt",
  "phase_steps": [500, 500],
  "level_weights": [1.0, 1.0, 1.0],
  "token_cache_path": "dataset_var_tokens",
  "synthetic_count": 100,
  "token_metadata": {
    "kind": "vq",
    "level_vocab_sizes": [4096, 2048, 32000],
    "level_lengths": [32, 128, 1024],
    "codebook_dim": 256,
    "max_token_length": 1184
  },
  "amp_enabled": true,
  "amp_dtype": "bf16",
  "compile_enabled": false,
  "pin_memory": true,
  "grad_accum_steps": 1,
  "flash_cross_entropy": true,
  "gradient_checkpointing": true,
  "use_early_exit_loss": false
}
