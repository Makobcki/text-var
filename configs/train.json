{
  "seed": 42,
  "device": "cuda",
  "batch_size": 1,
  "learning_rate": 6e-5,
  "weight_decay": 0.01,
  "max_steps": 90000,
  "grad_clip_norm": 0.5,
  "save_every": 4000,
  "max_checkpoints": 5,
  "checkpoint_path": "checkpoints/var_mbpp.pt",
  "phase_steps": [30000, 30000, 30000],
  "level_weights": [1.0, 1.0, 1.0],
  "token_cache_path": "dataset",
  "synthetic_count": 100,
  "token_metadata": {
    "kind": "vq",
    "level_vocab_sizes": [4096, 4096, 32000],
    "level_lengths": [64, 128, 512],
    "codebook_dim": 256,
    "max_token_length": 704
  },
  "amp_enabled": true,
  "amp_dtype": "bf16",
  "compile_enabled": false,
  "pin_memory": true,
  "grad_accum_steps": 2,
  "flash_cross_entropy": true,
  "gradient_checkpointing": true,
  "use_early_exit_loss": false,
  "optimizer": "adamw8bit",
  "tensorboard_enabled": true,
  "log_dir": "runs/var_mbpp",
  "log_grad_norm_every": 50,
  "log_weight_norm_every": 25,
  "sample_every": 150,
  "sample_prompt": "instruction: Write a function to check if the given integer is a prime number.",
  "sample_max_new_tokens": 128,
  "wandb_enabled": true,
  "wandb_project": "text-var"
}
