{
  "output": "checkpoints/vqvae.pt",
  "token_cache_dir": "dataset",
  "steps": 1000000000,
  "epochs": 1,
  "max_checkpoints": 5,
  "save_every": 1500,
  "batch_size": 8,
  "device": "cuda",
  "vocab_size": 32000,
  "hidden_size": 1024,
  "num_semantic_tokens": 4096,
  "semantic_sequence_length": 128,
  "pad_token_id": 0,
  "semantic_pad_token_id": 0,
  "max_position_embeddings": 8192,
  "lr": 6.0e-4,
  "level_index": 2,
  "gradient_accumulation_steps": 64,
  "dataloader_num_workers": 8,
  "dataloader_prefetch_factor": 2,
  "amp_dtype": "bf16",
  "use_fp8": false,
  "use_torch_compile": true,
  "log_every_steps": 10,
  "scheduler_type": "onecycle",
  "verbose": false,
  "use_triton_ema": true,
  "use_turboquant_kv": false,
  "turboquant_key_bits": 4,
  "turboquant_value_bits": 4,
  "turboquant_qjl_residual_scale": 0.5,
  "gradient_checkpointing": true,
  "use_unpadding": true,
  "use_rotary_embeddings": true,
  "word_dropout_prob": 0.1,
  "encoder_num_heads": 16,
  "encoder_depth": 12,
  "encoder_mlp_ratio": 4.0,
  "encoder_dropout": 0.1,
  "compression_rate": 4,
  "downsample_num_blocks": 2,
  "fsq_levels": [8, 8, 8, 8, 8, 8],
  "decoder_num_heads": 16,
  "decoder_depth": 12,
  "decoder_mlp_ratio": 4.0,
  "decoder_dropout": 0.1,
  "optimizer": "adamw8bit"
}
